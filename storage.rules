rules_version = '2';

// Deny-by-default. Uploads are members-only images, written only by their
// owner. All app images are re-encoded client-side before upload (EXIF/GPS
// stripped); these rules cap size/type as the server-side backstop.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedImage() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)')
        && request.resource.size < 10 * 1024 * 1024;
    }

    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Profile photos AND couple cover images: any member may view; only the
    // owner may write. Couple covers are uploaded by a partner into their own
    // space (folder "profile" or "couple-cover") — no cross-service read
    // needed. Partner-only control of the couple's coverPhotoURL field is
    // enforced in Firestore rules (only a partner can write it).
    match /users/{uid}/{folder}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && folder in ['profile', 'couple-cover']
        && isAllowedImage();
      allow delete: if isSignedIn() && request.auth.uid == uid
        && folder in ['profile', 'couple-cover'];
    }

    // Legacy couple cover path (seeded/older files): read-only. New covers are
    // written under users/{uid}/couple-cover/ above.
    match /couples/{coupleId}/cover/{fileName} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Post images: uploader-scoped path; any member may view.
    match /posts/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && isAllowedImage();
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // Event cover photos: uploader-scoped path; any member may view.
    match /events/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && isAllowedImage();
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // Album photo files: uploader-scoped writes. Reads are owner-only at the
    // storage layer — viewers receive tokenized download URLs through the
    // Firestore `albums/{id}/photos` docs, which enforce the album's access
    // level. (Note: a previously shared token URL keeps working until the
    // file is deleted; revoking a grant gates the doc, not old URLs.)
    match /albums/{uid}/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && isAllowedImage();
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    // Verification selfies: locked path — the uploader may write (and later
    // delete a pending one); ONLY admins may view.
    match /verifications/{uid}/{fileName} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && isAllowedImage();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
